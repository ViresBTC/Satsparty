# ── Frontend (Vite) ──
# Tu Nostr Wallet Connect URL (para testing directo sin backend)
NWC_URL=nostr+walletconnect://...

# Tu Lightning Address para testing
LIGHTNING_ADDRESS=tu@email.com

# ── Backend ──
# PostgreSQL connection string (Neon — free at https://neon.tech)
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# Admin password para el panel de administración
ADMIN_PASSWORD=mi-password-seguro

# JWT secret para sesiones (generá uno random)
JWT_SECRET=cambiar-esto-por-algo-random-de-32-chars

# Puerto del backend
PORT=3001

# ── Alby Hub (se configura por evento en el admin panel) ──
# ALBYHUB_URL=https://mi-albyhub.ejemplo.com
# ALBYHUB_AUTH_TOKEN=eyJhbGciOi...
