{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/prices",
      "destination": "/api/prices"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/[...route]"
    },
    {
      "source": "/.well-known/lnurlp/(.*)",
      "destination": "/api/[...route]"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/onboard/:code",
      "destination": "/index.html"
    }
  ]
}
