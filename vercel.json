{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/prices",
      "destination": "/api/prices"
    },
    {
      "source": "/api/db-test",
      "destination": "/api/db-test"
    },
    {
      "source": "/api/auth/(.*)",
      "destination": "/api/auth/$1"
    },
    {
      "source": "/api/events/(.*)",
      "destination": "/api/events/$1"
    },
    {
      "source": "/api/onboard/(.*)",
      "destination": "/api/onboard/$1"
    },
    {
      "source": "/.well-known/lnurlp/(.*)",
      "destination": "/api/lnurlp/$1"
    },
    {
      "source": "/onboard/:code",
      "destination": "/index.html"
    }
  ]
}
